{
  "name": "lex-law-next",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lex Law Next v1 — AI-assisted legal drafting system for The Satterwhite Law Firm PLLC",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src --ext .ts,.tsx",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/server/index.js --packages=external",
    "start": "node dist/server/index.js",
    "start:dev": "tsx src/server/index.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.30.0",
    "express": "^4.18.0",
    "handlebars": "^4.7.9",
    "iron-session": "^8.0.0",
    "lucide-react": "^1.11.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "mysql2": "^3.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.22.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/handlebars": "^4.1.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.4.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "drizzle-kit": "^0.20.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  }
}

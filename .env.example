# ============================================================
# Lex Law Next v1 — Environment Variables
# Copy this file to .env.local for development.
# See Chapter 3.6 of the specification for full documentation.
# ============================================================

# Database (TiDB-compatible MySQL connection string)
DATABASE_URL="mysql://user:password@host:4000/lex_law_next?ssl=true"

# Session (iron-session secret — must be at least 32 characters)
SESSION_SECRET="change-me-to-a-random-32-plus-char-string"

# Seed credentials (used by initial migration to create the single attorney user)
# SEED_PASSWORD_HASH should be a bcrypt hash of the desired password.
# Generate with: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',12))"
SEED_USERNAME="kelly"
SEED_PASSWORD_HASH="$2b$12$placeholder-replace-with-real-bcrypt-hash"

# LLM providers (Ch 3.5)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_API_KEY=""
XAI_API_KEY=""  # Optional — Grok omitted from UI when absent

# LLM model selection (Ch 22.2 / decision #41)
# Format: provider:model-name
PRIMARY_DRAFTER_MODEL="anthropic:claude-opus-4-5"
EVALUATOR_MODEL="anthropic:claude-opus-4-5"

# Storage backend (Ch 3.4)
# Values: "filesystem" | "s3"
STORAGE_BACKEND="filesystem"
# For filesystem: uploads go to /uploads/<matterId>/<materialId>/<filename>
# For S3:
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_ENDPOINT=""  # For MinIO or custom S3-compatible endpoint

# Server port
PORT=3001
